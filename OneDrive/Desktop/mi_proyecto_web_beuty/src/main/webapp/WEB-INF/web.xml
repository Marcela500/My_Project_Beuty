<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <!-- Configuración del servlet para manejar el registro de usuarios -->
    <servlet>
        <servlet-name>RegistroUsuarioServlet</servlet-name>
        <servlet-class>com.servlets.RegistroUsuarioServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegistroUsuarioServlet</servlet-name>
        <url-pattern>/registro</url-pattern>
    </servlet-mapping>

    <!-- Configuración del servlet para manejar el inicio de sesión -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.servlets.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- Configuración del servlet para manejar la lista de usuarios -->
    <servlet>
        <servlet-name>ListaUsuariosServlet</servlet-name>
        <servlet-class>com.servlets.ListaUsuariosServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ListaUsuariosServlet</servlet-name>
        <url-pattern>/listaUsuarios</url-pattern>
    </servlet-mapping>

    <!-- Configuración del servlet para manejar la edición de usuario -->
    <servlet>
        <servlet-name>EditarUsuarioServlet</servlet-name>
        <servlet-class>com.servlets.EditarUsuarioServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EditarUsuarioServlet</servlet-name>
        <url-pattern>/editarUsuario</url-pattern>
    </servlet-mapping>

    <!-- Configuración del servlet para manejar la eliminación de usuario -->
    <servlet>
        <servlet-name>EliminarUsuarioServlet</servlet-name>
        <servlet-class>com.servlets.EliminarUsuarioServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EliminarUsuarioServlet</servlet-name>
        <url-pattern>/eliminarUsuario</url-pattern>
    </servlet-mapping>

    <!-- Configuración del servlet para manejar la autenticación -->
    <servlet>
        <servlet-name>AuthenticationServlet</servlet-name>
        <servlet-class>com.servlets.AuthenticationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AuthenticationServlet</servlet-name>
        <url-pattern>/authenticate</url-pattern>
    </servlet-mapping>

    <!-- Configuración de la página de inicio -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Configuración de los recursos -->
    <resource-ref>
        <description>Base de datos de miTienda</description>
        <res-ref-name>jdbc/miTiendaDB</res-ref-name>
        <res-type>javax.sql.DataSource</res-type>
        <res-auth>Container</res-auth>
    </resource-ref>

</web-app>
