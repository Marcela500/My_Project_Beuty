<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
    <error-page>
        <error-code>404</error-code>
        <location>/error</location>
    </error-page>
    <error-page>
        <exception-type>java.lang.Throwable</exception-type>
        <location>/error</location>
    </error-page>
    <servlet>
        <servlet-name>RegistroServlet</servlet-name>
        <servlet-class>com.mycompany.mi_proyecto_beuty.servlets.RegistroServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegistroServlet</servlet-name>
        <url-pattern>/registro</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.mycompany.mi_proyecto_beuty.servlets.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>MainServlet</servlet-name>
        <servlet-class>com.mycompany.mi_proyecto_beuty.servlets.MainServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MainServlet</servlet-name>
        <url-pattern>/main</url-pattern>
    </servlet-mapping>
    <!-- Añadido ProductoServlet -->
    <servlet>
        <servlet-name>ProductoServlet</servlet-name>
        <servlet-class>com.mycompany.mi_proyecto_beuty.servlets.ProductoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProductoServlet</servlet-name>
        <url-pattern>/producto</url-pattern>
    </servlet-mapping>
    <!-- Añadido ServletDeRecuperacionContraseña -->
    <servlet>
        <servlet-name>ServletDeRecuperacionContraseña</servlet-name>
        <servlet-class>com.mycompany.mi_proyecto_beuty.servlets.ServletDeRecuperacionContraseña</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ServletDeRecuperacionContraseña</servlet-name>
        <url-pattern>/recuperacion</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>TestConnectionServlet</servlet-name>
        <servlet-class>com.mycompany.mi_proyecto_beuty.TestConnectionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TestConnectionServlet</servlet-name>
        <url-pattern>/testConnection</url-pattern>
    </servlet-mapping>
</web-app>
